{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start docs site (requires nightly)",
      "type": "process",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "pwsh",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "${workspaceFolder}/eng/scripts/Watch-RustDocs.ps1"
      ],
      "isBackground": true,
      "problemMatcher": [
        "$rustc",
        {
          "owner": "powershell",
          "fileLocation": [
            "absolute"
          ],
          "severity": "error",
          "pattern": {
            "regexp": "^\\[Error in file (.+?)\\](.*)$",
            "file": 1,
            "message": 2
          }
        }
      ]
    }
  ]
}
